# ---- Google (browser key: restrict by domain + APIs) ----
# Enables Places Autocomplete + the interactive map in the browser.
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=

# ---- Google (server keys: never exposed to the browser) ----
GOOGLE_MAPS_SERVER_KEY=
GOOGLE_WEATHER_API_KEY=

# ---- Delivery pricing (configurable; defaults match the spec) ----
DELIVERY_PLATFORM_FEE=0.40
DELIVERY_FIRST_3KM_FEE=5.00
DELIVERY_ADDITIONAL_KM_FEE=1.00
DELIVERY_PRICE_MARKUP_PERCENT=50
DELIVERY_QUOTE_VALID_MINUTES=10

# ---- WhatsApp ----
NEXT_PUBLIC_WHATSAPP_NUMBER=

# ---- Supabase (orders + payment lifecycle) ----
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Token an admin must send (x-admin-token header) to confirm a payment.
ADMIN_CONFIRM_TOKEN=
